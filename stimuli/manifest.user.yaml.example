# Copy to stimuli/manifest.user.yaml (gitignored) for personal tracks.
#
# 1. Put source files in stimuli/user/raw/<id>/  (any .mp3/.wav/.flac name)
# 2. Run: ./scripts/prepare_stimuli.sh --user
# 3. Processed output → stimuli/user/processed/<id>.wav
#
# Omit duration_s for full-length clips. Optional trim_start skips an intro.
bundle: user_v2
tracks:
  - id: my_song
    path: stimuli/user/processed/my_song.wav
    genre: indie
    user_supplied: true
    license: "User-owned — not redistributed"
    # trim_start: "00:00:00"   # optional
    # duration_s: 45            # optional clip; omit for full length

  - id: succession_theme
    path: stimuli/user/processed/succession_theme.wav
    genre: tv_score
    user_supplied: true
    license: "User-owned — not redistributed"
    trim_start: "00:00:15"
    duration_s: 45
