# Copy to .env and adjust paths if needed:
#   cp .env.example .env

# PyTorch MPS — allow CPU fallback for unsupported ops on Apple Silicon
PYTORCH_ENABLE_MPS_FALLBACK=1

# HuggingFace Hub cache (TRIBE + Wav2Vec weights, ~2–3 GB on first predict)
HF_HOME=./data/weights/huggingface

# tribev2 feature / embedding cache
NERVE_CACHE=./data/features

# Run artifacts and export-web bundles (Next.js reads {NERVE_OUTPUTS}/runs/*/web/)
NERVE_OUTPUTS=./data/outputs

# Inference device: auto | mps | cpu
NERVE_DEVICE=auto
